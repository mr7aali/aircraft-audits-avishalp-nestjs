  ACTIVE
  INACTIVE
  LOCKED
}

enum RecoveryType {
  PASSWORD_RESET
  UID_RECOVERY
}

enum RecoveryStatus {
  REQUESTED
  SENT
  COMPLETED
  EXPIRED
  FAILED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum FileCategory {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  SIGNATURE
}

enum ScanStatus {
  PENDING
  CLEAN
  INFECTED
  FAILED
}

enum AuditRecordStatus {
  DRAFT
  SUBMITTED
}

enum YesNoNa {
  YES
  NO
  NA
}

enum PassFail {
  PASS
  FAIL
}

enum DelayType {
  PRIMARY
  SECONDARY
}

enum RatingScale {
  VERY_POOR
  POOR
  FAIR
  GOOD
  VERY_GOOD
}

enum ConversationType {
  DIRECT
  GROUP
}

enum ConversationMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  DOCUMENT
  VIDEO
  LOCATION
  CONTACT
  POLL
  EVENT
  SYSTEM
}

enum AttachmentKind {
  IMAGE
  AUDIO
  DOCUMENT
  VIDEO
}

enum LocationType {
  CURRENT
  LIVE
  SEARCHED
}

enum CallType {
  VIDEO
  VOICE
}

