generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id              String              @id @default(uuid()) @db.Uuid
  code            String              @unique
  name            String
  isActive        Boolean             @default(true)
  createdAt       DateTime @db.Timestamptz(3)            @default(now())
  updatedAt       DateTime @db.Timestamptz(3)            @updatedAt
  moduleAccesses  RoleModuleAccess[]
  stationAccesses UserStationAccess[]

  @@map("roles")
}

model User {
  id                           String                        @id @default(uuid()) @db.Uuid
  uid                          String                        @unique
  email                        String                        @unique
  passwordHash                 String
  firstName                    String
  lastName                     String
  phone                        String?
  profileImageFileId           String?                       @db.Uuid
  publishedAt                  DateTime? @db.Timestamptz(3)
  status                       UserStatus                    @default(ACTIVE)
  failedLoginCount             Int                           @default(0)
  lockedUntil                  DateTime? @db.Timestamptz(3)
  lastSeenAt                   DateTime? @db.Timestamptz(3)
  createdAt                    DateTime @db.Timestamptz(3)                      @default(now())
  updatedAt                    DateTime @db.Timestamptz(3)                      @updatedAt
  accountRecoveryRequests      AccountRecoveryRequest[]
  feedbacks                    AppFeedback[]
  authSessions                 AuthSession[]
  cabinQualityAudits           CabinQualityAudit[]
  cabinSecuritySearchTrainings CabinSecuritySearchTraining[]
  chatParticipants             ChatConversationParticipant[]
  createdChatConversations     ChatConversation[]            @relation("ChatConversationCreatedBy")
  chatReceipts                 ChatMessageReceipt[]          @relation("ChatMessageRecipient")
  sentChatMessages             ChatMessage[]                 @relation("ChatMessageSender")
  chatPollVotes                ChatPollVote[]
  emailNotifications           EmailNotification[]
  attendedOneOnOnes            EmployeeOneOnOne[]            @relation("EmployeeOneOnOnes")
  ledOneOnOnes                 EmployeeOneOnOne[]            @relation("LeaderOneOnOnes")
  endOfShiftReports            EndOfShiftReport[]
  uploadedFiles                File[]                        @relation("UserUploadedFiles")
  lavSafetyObservations        LavSafetyObservation[]
  loginAuditLogs               LoginAuditLog[]
  stationAccesses              UserStationAccess[]
  profileImageFile             File?                         @relation("UserProfileImage", fields: [profileImageFileId], references: [id])

  @@index([firstName, lastName])
  @@map("users")
}

model Station {
  id                           String                        @id @default(uuid()) @db.Uuid
  code                         String                        @unique
  airportCode                  String?
  name                         String
  timezone                     String
  isActive                     Boolean                       @default(true)
  createdAt                    DateTime @db.Timestamptz(3)                      @default(now())
  updatedAt                    DateTime @db.Timestamptz(3)                      @updatedAt
  feedbacks                    AppFeedback[]
  authSessions                 AuthSession[]
  cabinQualityAudits           CabinQualityAudit[]
  cabinSecuritySearchTrainings CabinSecuritySearchTraining[]
  chatConversations            ChatConversation[]
  employeeOneOnOnes            EmployeeOneOnOne[]
  endOfShiftReports            EndOfShiftReport[]
  gates                        Gate[]
  lavSafetyObservations        LavSafetyObservation[]
  shiftDefinitions             ShiftDefinition[]
  shiftOccurrences             ShiftOccurrence[]
  userAccesses                 UserStationAccess[]

  @@map("stations")
}

model Gate {
  id                           String                        @id @default(uuid()) @db.Uuid
  stationId                    String                        @db.Uuid
  gateCode                     String
  name                         String?
  isActive                     Boolean                       @default(true)
  createdAt                    DateTime @db.Timestamptz(3)                      @default(now())
  updatedAt                    DateTime @db.Timestamptz(3)                      @updatedAt
  cabinQualityAudits           CabinQualityAudit[]
  cabinSecuritySearchTrainings CabinSecuritySearchTraining[]
  station                      Station                       @relation(fields: [stationId], references: [id])
  lavSafetyObservations        LavSafetyObservation[]

  @@unique([stationId, gateCode])
  @@index([stationId])
  @@map("gates")
}

model UserStationAccess {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  stationId String   @db.Uuid
  roleId    String   @db.Uuid
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @db.Timestamptz(3) @default(now())
  updatedAt DateTime @db.Timestamptz(3) @updatedAt
  role      Role     @relation(fields: [roleId], references: [id])
  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stationId])
  @@index([stationId, roleId])
  @@map("user_station_access")
}

model AppModule {
  id           String             @id @default(uuid()) @db.Uuid
  code         String             @unique
  name         String
  roleAccesses RoleModuleAccess[]

  @@map("app_modules")
}

model RoleModuleAccess {
  id        String    @id @default(uuid()) @db.Uuid
  roleId    String    @db.Uuid
  moduleId  String    @db.Uuid
  canList   Boolean   @default(false)
  canView   Boolean   @default(false)
  canCreate Boolean   @default(false)
  module    AppModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId])
  @@map("role_module_access")
}

model ShiftDefinition {
  id                 String            @id @default(uuid()) @db.Uuid
  stationId          String            @db.Uuid
  code               String
  name               String
  startsLocalMinutes Int
  endsLocalMinutes   Int
  isActive           Boolean           @default(true)
  station            Station           @relation(fields: [stationId], references: [id], onDelete: Cascade)
  occurrences        ShiftOccurrence[]

  @@unique([stationId, code])
  @@map("shift_definitions")
}

model ShiftOccurrence {
  id                           String                        @id @default(uuid()) @db.Uuid
  stationId                    String                        @db.Uuid
  shiftDefinitionId            String                        @db.Uuid
  businessDate                 DateTime                      @db.Date
  startsAt                     DateTime @db.Timestamptz(3)
  endsAt                       DateTime @db.Timestamptz(3)
  cabinQualityAudits           CabinQualityAudit[]
  cabinSecuritySearchTrainings CabinSecuritySearchTraining[]
  endOfShiftReports            EndOfShiftReport[]
  lavSafetyObservations        LavSafetyObservation[]
  shiftDefinition              ShiftDefinition               @relation(fields: [shiftDefinitionId], references: [id], onDelete: Cascade)
  station                      Station                       @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([stationId, shiftDefinitionId, businessDate])
  @@index([stationId, businessDate])
  @@map("shift_occurrences")
}

model CleanType {
  id                 String              @id @default(uuid()) @db.Uuid
  code               String              @unique
  name               String
  sortOrder          Int                 @default(0)
  isActive           Boolean             @default(true)
  cabinQualityAudits CabinQualityAudit[]

  @@map("clean_types")
}

model File {
  id                                   String                                  @id @default(uuid()) @db.Uuid
  storageKey                           String                                  @unique
  originalFileName                     String
  mimeType                             String
  sizeBytes                            BigInt
  checksumSha256                       String?
  metadataJson                         Json?
  durationSeconds                      Int?
  fileCategory                         FileCategory
  scanStatus                           ScanStatus                              @default(PENDING)
  encryptedAtRest                      Boolean                                 @default(false)
  uploadedByUserId                     String?                                 @db.Uuid
  createdAt                            DateTime @db.Timestamptz(3)                                @default(now())
  cabinQualityAuditLinks               CabinQualityAuditFile[]
  cabinQualityResponseLinks            CabinQualityAuditResponseFile[]
  cabinQualitySignatureFor             CabinQualityAudit[]                     @relation("CabinQualityAuditSignature")
  securityTrainingLinks                CabinSecuritySearchTrainingFile[]
  securityTrainingResultLinks          CabinSecuritySearchTrainingResultFile[]
  chatConversationAvatarFor            ChatConversation[]                      @relation("ChatConversationAvatar")
  chatMessageFileLinks                 ChatMessageFile[]
  employeeOneOnOneAudioFor             EmployeeOneOnOne[]                      @relation("EmployeeOneOnOneAudio")
  employeeOneOnOneEmployeeSignatureFor EmployeeOneOnOne[]                      @relation("EmployeeOneOnOneEmployeeSignature")
  employeeOneOnOneLeaderSignatureFor   EmployeeOneOnOne[]                      @relation("EmployeeOneOnOneLeaderSignature")
  endOfShiftReportLinks                EndOfShiftReportFile[]
  uploadedByUser                       User?                                   @relation("UserUploadedFiles", fields: [uploadedByUserId], references: [id])
  lavSafetyObservationLinks            LavSafetyObservationFile[]
  lavSafetyResponseLinks               LavSafetyObservationResponseFile[]
  lavSafetySignatureFor                LavSafetyObservation[]                  @relation("LavSafetyObservationSignature")
  userProfileImageFor                  User[]                                  @relation("UserProfileImage")

  @@index([uploadedByUserId])
  @@index([fileCategory, scanStatus])
  @@map("files")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  activeStationId  String?   @db.Uuid
  refreshTokenHash String    @unique
  rememberMe       Boolean   @default(false)
  deviceId         String?
  deviceName       String?
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime @db.Timestamptz(3)
  lastUsedAt       DateTime? @db.Timestamptz(3)
  revokedAt        DateTime? @db.Timestamptz(3)
  createdAt        DateTime @db.Timestamptz(3)  @default(now())
  activeStation    Station?  @relation(fields: [activeStationId], references: [id])
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([activeStationId])
  @@map("auth_sessions")
}

model AccountRecoveryRequest {
  id             String              @id @default(uuid()) @db.Uuid
  userId         String?             @db.Uuid
  requestedEmail String
  recoveryType   RecoveryType
  tokenHash      String?             @unique
  expiresAt      DateTime? @db.Timestamptz(3)
  consumedAt     DateTime? @db.Timestamptz(3)
  status         RecoveryStatus      @default(REQUESTED)
  requestedIp    String?
  createdAt      DateTime @db.Timestamptz(3)            @default(now())
  user           User?               @relation(fields: [userId], references: [id])
  notifications  EmailNotification[]

  @@index([requestedEmail, createdAt])
  @@map("account_recovery_requests")
}

model EmailNotification {
  id                String                  @id @default(uuid()) @db.Uuid
  requestId         String?                 @db.Uuid
  userId            String?                 @db.Uuid
  emailTo           String
  templateCode      String
  subject           String
  payloadJson       Json?
  providerMessageId String?                 @unique
  status            NotificationStatus      @default(PENDING)
  sentAt            DateTime? @db.Timestamptz(3)
  failedAt          DateTime? @db.Timestamptz(3)
  createdAt         DateTime @db.Timestamptz(3)                @default(now())
  request           AccountRecoveryRequest? @relation(fields: [requestId], references: [id])
  user              User?                   @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@map("email_notifications")
}

model LoginAuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @db.Uuid
  attemptedUid  String
  success       Boolean
  failureReason String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @db.Timestamptz(3) @default(now())
  user          User?    @relation(fields: [userId], references: [id])

  @@index([attemptedUid, createdAt])
  @@index([userId, createdAt])
  @@map("login_audit_logs")
}

model CabinQualityChecklistItem {
  id        String                      @id @default(uuid()) @db.Uuid
  code      String                      @unique
  label     String
  sortOrder Int                         @default(0)
  isActive  Boolean                     @default(true)
  responses CabinQualityAuditResponse[]

  @@map("cabin_quality_checklist_items")
}

model CabinQualityAudit {
  id                  String                      @id @default(uuid()) @db.Uuid
  stationId           String                      @db.Uuid
  shiftOccurrenceId   String?                     @db.Uuid
  gateId              String                      @db.Uuid
  cleanTypeId         String                      @db.Uuid
  auditorUserId       String                      @db.Uuid
  auditorNameSnapshot String
  auditorRoleSnapshot String
  gateCodeSnapshot    String
  cleanTypeSnapshot   String
  auditAt             DateTime @db.Timestamptz(3)                    @default(now())
  otherFindings       String?
  additionalNotes     String?
  signatureFileId     String                      @db.Uuid
  status              AuditRecordStatus           @default(SUBMITTED)
  submittedAt         DateTime @db.Timestamptz(3)                    @default(now())
  createdAt           DateTime @db.Timestamptz(3)                    @default(now())
  updatedAt           DateTime @db.Timestamptz(3)                    @updatedAt
  files               CabinQualityAuditFile[]
  responses           CabinQualityAuditResponse[]
  auditorUser         User                        @relation(fields: [auditorUserId], references: [id])
  cleanType           CleanType                   @relation(fields: [cleanTypeId], references: [id])
  gate                Gate                        @relation(fields: [gateId], references: [id])
  shiftOccurrence     ShiftOccurrence?            @relation(fields: [shiftOccurrenceId], references: [id])
  signatureFile       File                        @relation("CabinQualityAuditSignature", fields: [signatureFileId], references: [id])
  station             Station                     @relation(fields: [stationId], references: [id])

  @@index([stationId, auditAt])
  @@index([auditorUserId])
  @@index([gateId])
  @@index([status])
  @@map("cabin_quality_audits")
}

model CabinQualityAuditResponse {
  id              String                          @id @default(uuid()) @db.Uuid
  auditId         String                          @db.Uuid
  checklistItemId String                          @db.Uuid
  response        YesNoNa
  files           CabinQualityAuditResponseFile[]
  audit           CabinQualityAudit               @relation(fields: [auditId], references: [id], onDelete: Cascade)
  checklistItem   CabinQualityChecklistItem       @relation(fields: [checklistItemId], references: [id])

  @@unique([auditId, checklistItemId])
  @@index([checklistItemId])
  @@map("cabin_quality_audit_responses")
}

model CabinQualityAuditResponseFile {
  responseId String                    @db.Uuid
  fileId     String                    @db.Uuid
  sortOrder  Int                       @default(0)
  file       File                      @relation(fields: [fileId], references: [id])
  response   CabinQualityAuditResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@id([responseId, fileId])
  @@index([fileId])
  @@map("cabin_quality_audit_response_files")
}

model CabinQualityAuditFile {
  auditId   String            @db.Uuid
  fileId    String            @db.Uuid
  sortOrder Int               @default(0)
  audit     CabinQualityAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  file      File              @relation(fields: [fileId], references: [id])

  @@id([auditId, fileId])
  @@index([fileId])
  @@map("cabin_quality_audit_files")
}

model LavSafetyChecklistItem {
  id        String                         @id @default(uuid()) @db.Uuid
  code      String                         @unique
  label     String
  sortOrder Int                            @default(0)
  isActive  Boolean                        @default(true)
  responses LavSafetyObservationResponse[]

  @@map("lav_safety_checklist_items")
}

model LavSafetyObservation {
  id                  String                         @id @default(uuid()) @db.Uuid
  stationId           String                         @db.Uuid
  shiftOccurrenceId   String?                        @db.Uuid
  gateId              String                         @db.Uuid
  auditorUserId       String                         @db.Uuid
  auditorNameSnapshot String
  auditorRoleSnapshot String
  gateCodeSnapshot    String
  observedAt          DateTime @db.Timestamptz(3)                       @default(now())
  driverName          String
  shipNumber          String
  otherFindings       String?
  additionalNotes     String?
  signatureFileId     String                         @db.Uuid
  status              AuditRecordStatus              @default(SUBMITTED)
  submittedAt         DateTime @db.Timestamptz(3)                       @default(now())
  createdAt           DateTime @db.Timestamptz(3)                       @default(now())
  updatedAt           DateTime @db.Timestamptz(3)                       @updatedAt
  files               LavSafetyObservationFile[]
  responses           LavSafetyObservationResponse[]
  auditorUser         User                           @relation(fields: [auditorUserId], references: [id])
  gate                Gate                           @relation(fields: [gateId], references: [id])
  shiftOccurrence     ShiftOccurrence?               @relation(fields: [shiftOccurrenceId], references: [id])
  signatureFile       File                           @relation("LavSafetyObservationSignature", fields: [signatureFileId], references: [id])
  station             Station                        @relation(fields: [stationId], references: [id])

  @@index([stationId, observedAt])
  @@index([auditorUserId])
  @@index([driverName])
  @@index([status])
  @@map("lav_safety_observations")
}

model LavSafetyObservationResponse {
  id              String                             @id @default(uuid()) @db.Uuid
  observationId   String                             @db.Uuid
  checklistItemId String                             @db.Uuid
  response        PassFail
  files           LavSafetyObservationResponseFile[]
  checklistItem   LavSafetyChecklistItem             @relation(fields: [checklistItemId], references: [id])
  observation     LavSafetyObservation               @relation(fields: [observationId], references: [id], onDelete: Cascade)

  @@unique([observationId, checklistItemId])
  @@index([checklistItemId])
  @@map("lav_safety_observation_responses")
}

model LavSafetyObservationResponseFile {
  responseId String                       @db.Uuid
  fileId     String                       @db.Uuid
  sortOrder  Int                          @default(0)
  file       File                         @relation(fields: [fileId], references: [id])
  response   LavSafetyObservationResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@id([responseId, fileId])
  @@index([fileId])
  @@map("lav_safety_observation_response_files")
}

model LavSafetyObservationFile {
  observationId String               @db.Uuid
  fileId        String               @db.Uuid
  sortOrder     Int                  @default(0)
  file          File                 @relation(fields: [fileId], references: [id])
  observation   LavSafetyObservation @relation(fields: [observationId], references: [id], onDelete: Cascade)

  @@id([observationId, fileId])
  @@index([fileId])
  @@map("lav_safety_observation_files")
}

model SecuritySearchArea {
  id              String                              @id @default(uuid()) @db.Uuid
  code            String                              @unique
  label           String
  sortOrder       Int                                 @default(0)
  isActive        Boolean                             @default(true)
  trainingResults CabinSecuritySearchTrainingResult[]

  @@map("security_search_areas")
}

model CabinSecuritySearchTraining {
  id                  String                              @id @default(uuid()) @db.Uuid
  stationId           String                              @db.Uuid
  shiftOccurrenceId   String?                             @db.Uuid
  gateId              String                              @db.Uuid
  auditorUserId       String                              @db.Uuid
  auditorNameSnapshot String
  auditorRoleSnapshot String
  gateCodeSnapshot    String
  trainingAt          DateTime @db.Timestamptz(3)                            @default(now())
  shipNumber          String
  otherFindings       String?
  additionalNotes     String?
  overallResult       PassFail
  status              AuditRecordStatus                   @default(SUBMITTED)
  submittedAt         DateTime @db.Timestamptz(3)                            @default(now())
  createdAt           DateTime @db.Timestamptz(3)                            @default(now())
  updatedAt           DateTime @db.Timestamptz(3)                            @updatedAt
  files               CabinSecuritySearchTrainingFile[]
  results             CabinSecuritySearchTrainingResult[]
  auditorUser         User                                @relation(fields: [auditorUserId], references: [id])
  gate                Gate                                @relation(fields: [gateId], references: [id])
  shiftOccurrence     ShiftOccurrence?                    @relation(fields: [shiftOccurrenceId], references: [id])
  station             Station                             @relation(fields: [stationId], references: [id])

  @@index([stationId, trainingAt])
  @@index([auditorUserId])
  @@index([overallResult])
  @@index([status])
  @@map("cabin_security_search_trainings")
}

model CabinSecuritySearchTrainingResult {
  id                String                                  @id @default(uuid()) @db.Uuid
  trainingId        String                                  @db.Uuid
  areaId            String                                  @db.Uuid
  areaLabelSnapshot String
  result            PassFail
  files             CabinSecuritySearchTrainingResultFile[]
  area              SecuritySearchArea                      @relation(fields: [areaId], references: [id])
  training          CabinSecuritySearchTraining             @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@unique([trainingId, areaId])
  @@index([areaId])
  @@map("cabin_security_search_training_results")
}

model CabinSecuritySearchTrainingResultFile {
  resultId  String                            @db.Uuid
  fileId    String                            @db.Uuid
  sortOrder Int                               @default(0)
  file      File                              @relation(fields: [fileId], references: [id])
  result    CabinSecuritySearchTrainingResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@id([resultId, fileId])
  @@index([fileId])
  @@map("cabin_security_search_training_result_files")
}

model CabinSecuritySearchTrainingFile {
  trainingId String                      @db.Uuid
  fileId     String                      @db.Uuid
  sortOrder  Int                         @default(0)
  file       File                        @relation(fields: [fileId], references: [id])
  training   CabinSecuritySearchTraining @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@id([trainingId, fileId])
  @@index([fileId])
  @@map("cabin_security_search_training_files")
}

model EndOfShiftReport {
  id                      String                  @id @default(uuid()) @db.Uuid
  stationId               String                  @db.Uuid
  shiftOccurrenceId       String?                 @db.Uuid
  supervisorUserId        String                  @db.Uuid
  supervisorNameSnapshot  String
  supervisorRoleSnapshot  String
  reportAt                DateTime @db.Timestamptz(3)                @default(now())
  lavObservationCompleted Boolean
  lavObservationReason    String?
  cabinQualityCompleted   Boolean
  cabinQualityReason      String?
  callOffs                Int
  tardyEarlyOut           Int
  overtimeHours           Int
  overtimeMinutes         Int
  overtimeReason          String?
  delaysTaken             Boolean
  delayCount              Int?
  additionalNotes         String?
  status                  AuditRecordStatus       @default(SUBMITTED)
  submittedAt             DateTime @db.Timestamptz(3)                @default(now())
  createdAt               DateTime @db.Timestamptz(3)                @default(now())
  updatedAt               DateTime @db.Timestamptz(3)                @updatedAt
  delays                  EndOfShiftReportDelay[]
  files                   EndOfShiftReportFile[]
  shiftOccurrence         ShiftOccurrence?        @relation(fields: [shiftOccurrenceId], references: [id])
  station                 Station                 @relation(fields: [stationId], references: [id])
  supervisorUser          User                    @relation(fields: [supervisorUserId], references: [id])

  @@index([stationId, reportAt])
  @@index([supervisorUserId])
  @@index([delaysTaken])
  @@index([status])
  @@map("end_of_shift_reports")
}

model EndOfShiftReportDelay {
  id              String           @id @default(uuid()) @db.Uuid
  reportId        String           @db.Uuid
  sequenceNo      Int
  delayCodeAlpha  String
  delayCodeNumber Int
  delayType       DelayType
  reason          String
  report          EndOfShiftReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, sequenceNo])
  @@index([delayCodeAlpha, delayCodeNumber])
  @@index([delayType])
  @@map("end_of_shift_report_delays")
}

model EndOfShiftReportFile {
  reportId  String           @db.Uuid
  fileId    String           @db.Uuid
  sortOrder Int              @default(0)
  file      File             @relation(fields: [fileId], references: [id])
  report    EndOfShiftReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@id([reportId, fileId])
  @@index([fileId])
  @@map("end_of_shift_report_files")
}

model EmployeeOneOnOne {
  id                      String            @id @default(uuid()) @db.Uuid
  stationId               String            @db.Uuid
  leaderUserId            String            @db.Uuid
  employeeUserId          String            @db.Uuid
  leaderNameSnapshot      String
  leaderRoleSnapshot      String
  employeeNameSnapshot    String
  meetingAt               DateTime @db.Timestamptz(3)          @default(now())
  discussionText          String?
  discussionAudioFileId   String?           @db.Uuid
  additionalNote          String?
  employeeRefusedToSign   Boolean           @default(false)
  employeeSignatureFileId String?           @db.Uuid
  leaderSignatureFileId   String            @db.Uuid
  status                  AuditRecordStatus @default(SUBMITTED)
  submittedAt             DateTime @db.Timestamptz(3)          @default(now())
  createdAt               DateTime @db.Timestamptz(3)          @default(now())
  updatedAt               DateTime @db.Timestamptz(3)          @updatedAt
  discussionAudioFile     File?             @relation("EmployeeOneOnOneAudio", fields: [discussionAudioFileId], references: [id])
  employeeSignatureFile   File?             @relation("EmployeeOneOnOneEmployeeSignature", fields: [employeeSignatureFileId], references: [id])
  employeeUser            User              @relation("EmployeeOneOnOnes", fields: [employeeUserId], references: [id])
  leaderSignatureFile     File              @relation("EmployeeOneOnOneLeaderSignature", fields: [leaderSignatureFileId], references: [id])
  leaderUser              User              @relation("LeaderOneOnOnes", fields: [leaderUserId], references: [id])
  station                 Station           @relation(fields: [stationId], references: [id])

  @@index([stationId, meetingAt])
  @@index([leaderUserId])
  @@index([employeeUserId])
  @@index([status])
  @@map("employee_one_on_ones")
}

model AppFeedback {
  id                  String      @id @default(uuid()) @db.Uuid
  stationId           String      @db.Uuid
  submittedByUserId   String      @db.Uuid
  userNameSnapshot    String
  userRoleSnapshot    String
  submittedAt         DateTime @db.Timestamptz(3)    @default(now())
  overallSatisfaction RatingScale
  easeOfUse           RatingScale
  appPerformance      RatingScale
  usabilityIssues     String?
  missingFeatures     String?
  performanceIssues   String?
  station             Station     @relation(fields: [stationId], references: [id])
  submittedByUser     User        @relation(fields: [submittedByUserId], references: [id])

  @@index([stationId, submittedAt])
  @@index([submittedByUserId])
  @@map("app_feedback")
}

model ChatConversation {
  id               String                        @id @default(uuid()) @db.Uuid
  conversationType ConversationType
  stationId        String?                       @db.Uuid
  createdByUserId  String                        @db.Uuid
  title            String?
  directPairKey    String?                       @unique
  avatarFileId     String?                       @db.Uuid
  lastMessageId    String?                       @unique @db.Uuid
  lastMessageAt    DateTime? @db.Timestamptz(3)
  createdAt        DateTime @db.Timestamptz(3)                      @default(now())
  updatedAt        DateTime @db.Timestamptz(3)                      @updatedAt
  participants     ChatConversationParticipant[]
  avatarFile       File?                         @relation("ChatConversationAvatar", fields: [avatarFileId], references: [id])
  createdByUser    User                          @relation("ChatConversationCreatedBy", fields: [createdByUserId], references: [id])
  lastMessage      ChatMessage?                  @relation("ChatConversationLastMessage", fields: [lastMessageId], references: [id])
  station          Station?                      @relation(fields: [stationId], references: [id])
  messages         ChatMessage[]                 @relation("ChatConversationMessages")

  @@index([conversationType, lastMessageAt])
  @@index([createdByUserId])
  @@map("chat_conversations")
}

model ChatConversationParticipant {
  id                String                 @id @default(uuid()) @db.Uuid
  conversationId    String                 @db.Uuid
  userId            String                 @db.Uuid
  memberRole        ConversationMemberRole @default(MEMBER)
  isFavorite        Boolean                @default(false)
  isMuted           Boolean                @default(false)
  lastReadMessageId String?                @db.Uuid
  lastReadAt        DateTime? @db.Timestamptz(3)
  joinedAt          DateTime @db.Timestamptz(3)               @default(now())
  leftAt            DateTime? @db.Timestamptz(3)
  conversation      ChatConversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lastReadMessage   ChatMessage?           @relation("ParticipantLastReadMessage", fields: [lastReadMessageId], references: [id])
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, isFavorite])
  @@index([conversationId])
  @@map("chat_conversation_participants")
}

model ChatMessage {
  id                     String                        @id @default(uuid()) @db.Uuid
  conversationId         String                        @db.Uuid
  senderUserId           String                        @db.Uuid
  messageType            MessageType
  encryptedPayload       String?
  previewText            String?
  createdAt              DateTime @db.Timestamptz(3)                      @default(now())
  editedAt               DateTime? @db.Timestamptz(3)
  deletedAt              DateTime? @db.Timestamptz(3)
  contact                ChatContact?
  lastReadByParticipants ChatConversationParticipant[] @relation("ParticipantLastReadMessage")
  lastForConversation    ChatConversation?             @relation("ChatConversationLastMessage")
  event                  ChatEvent?
  location               ChatLocation?
  files                  ChatMessageFile[]
  receipts               ChatMessageReceipt[]
  conversation           ChatConversation              @relation("ChatConversationMessages", fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser             User                          @relation("ChatMessageSender", fields: [senderUserId], references: [id])
  poll                   ChatPoll?

  @@index([conversationId, createdAt])
  @@index([senderUserId, createdAt])
  @@map("chat_messages")
}

model ChatMessageReceipt {
  messageId       String      @db.Uuid
  recipientUserId String      @db.Uuid
  deliveredAt     DateTime? @db.Timestamptz(3)
  readAt          DateTime? @db.Timestamptz(3)
  message         ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipientUser   User        @relation("ChatMessageRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@id([messageId, recipientUserId])
  @@index([recipientUserId, readAt])
  @@map("chat_message_receipts")
}

model ChatMessageFile {
  id             String         @id @default(uuid()) @db.Uuid
  messageId      String         @db.Uuid
  fileId         String         @db.Uuid
  attachmentKind AttachmentKind
  sortOrder      Int            @default(0)
  file           File           @relation(fields: [fileId], references: [id])
  message        ChatMessage    @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, fileId])
  @@index([messageId, sortOrder])
  @@map("chat_message_files")
}

model ChatPoll {
  messageId            String           @id @db.Uuid
  question             String
  allowMultipleAnswers Boolean          @default(false)
  options              ChatPollOption[]
  message              ChatMessage      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("chat_polls")
}

model ChatPollOption {
  id            String         @id @default(uuid()) @db.Uuid
  pollMessageId String         @db.Uuid
  optionText    String
  sortOrder     Int            @default(0)
  poll          ChatPoll       @relation(fields: [pollMessageId], references: [messageId], onDelete: Cascade)
  votes         ChatPollVote[]

  @@unique([pollMessageId, sortOrder])
  @@map("chat_poll_options")
}

model ChatPollVote {
  id          String         @id @default(uuid()) @db.Uuid
  optionId    String         @db.Uuid
  voterUserId String         @db.Uuid
  votedAt     DateTime @db.Timestamptz(3)       @default(now())
  option      ChatPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  voterUser   User           @relation(fields: [voterUserId], references: [id], onDelete: Cascade)

  @@unique([optionId, voterUserId])
  @@index([voterUserId])
  @@map("chat_poll_votes")
}

model ChatEvent {
  messageId             String      @id @db.Uuid
  eventName             String
  description           String?
  startAt               DateTime @db.Timestamptz(3)
  endAt                 DateTime? @db.Timestamptz(3)
  locationText          String?
  callType              CallType?
  callLinkUrl           String?
  reminderOffsetMinutes Int?
  allowGuests           Boolean     @default(false)
  message               ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("chat_events")
}

model ChatLocation {
  messageId     String       @id @db.Uuid
  locationType  LocationType
  latitude      Decimal      @db.Decimal(10, 7)
  longitude     Decimal      @db.Decimal(10, 7)
  addressText   String?
  liveExpiresAt DateTime? @db.Timestamptz(3)
  lastUpdatedAt DateTime? @db.Timestamptz(3)
  message       ChatMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("chat_locations")
}

model ChatContact {
  messageId    String      @id @db.Uuid
  contactName  String
  contactPhone String
  contactEmail String?
  message      ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("chat_contacts")
}

