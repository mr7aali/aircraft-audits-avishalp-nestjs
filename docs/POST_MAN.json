  "info": {
    "title": "Station Audit Platform API",
    "description": "Operational station audit and communication backend",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": { "scheme": "bearer", "bearerFormat": "JWT", "type": "http" }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "userId": { "type": "string", "minLength": 1, "maxLength": 50 },
          "password": { "type": "string", "minLength": 8, "maxLength": 20 },
          "rememberMe": { "type": "object", "default": false },
          "deviceId": { "type": "string" },
          "deviceName": { "type": "string" }
        },
        "required": ["userId", "password"]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": { "refreshToken": { "type": "string" } },
        "required": ["refreshToken"]
      },
      "LogoutDto": {
        "type": "object",
        "properties": { "refreshToken": { "type": "string" } }
      },
      "ForgotPasswordRequestDto": {
        "type": "object",
        "properties": { "email": { "type": "string" } },
        "required": ["email"]
      },
      "ForgotPasswordConfirmDto": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "newPassword": { "type": "string", "minLength": 8, "maxLength": 20 }
        },
        "required": ["token", "newPassword"]
      },
      "ForgotUidRequestDto": {
        "type": "object",
        "properties": { "email": { "type": "string" } },
        "required": ["email"]
      },
      "SelectStationDto": {
        "type": "object",
        "properties": { "stationId": { "type": "string" } },
        "required": ["stationId"]
      },
      "UploadFileDto": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": ["IMAGE", "VIDEO", "AUDIO", "DOCUMENT", "SIGNATURE"]
          }
        }
      },
      "Object": { "type": "object", "properties": {} },
      "CabinQualityAuditResponseInputDto": {
        "type": "object",
        "properties": {
          "checklistItemId": { "type": "string" },
          "response": { "type": "string", "enum": ["YES", "NO", "NA"] },
          "imageFileIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["checklistItemId", "response"]
      },
      "CreateCabinQualityAuditDto": {
        "type": "object",
        "properties": {
          "gateId": { "type": "string" },
          "cleanTypeId": { "type": "string" },
          "shiftOccurrenceId": { "type": "string" },
          "responses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CabinQualityAuditResponseInputDto"
            }
          },
          "signatureFileId": { "type": "string" },
          "otherFindings": { "type": "string" },
          "additionalNotes": { "type": "string" },
          "generalPictureFileIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["gateId", "cleanTypeId", "responses", "signatureFileId"]
      },
      "LavSafetyResponseInputDto": {
        "type": "object",
        "properties": {
          "checklistItemId": { "type": "string" },
          "response": { "type": "string", "enum": ["PASS", "FAIL"] },
          "imageFileIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["checklistItemId", "response"]
      },
      "CreateLavSafetyObservationDto": {
        "type": "object",
        "properties": {
          "driverName": { "type": "string" },
          "shipNumber": { "type": "string" },
          "gateId": { "type": "string" },
          "shiftOccurrenceId": { "type": "string" },
          "responses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LavSafetyResponseInputDto"
            }
          },
          "signatureFileId": { "type": "string" },
          "otherFindings": { "type": "string" },
          "additionalNotes": { "type": "string" },
          "generalPictureFileIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": [
          "driverName",
          "shipNumber",
          "gateId",
          "responses",
          "signatureFileId"
        ]
      },
      "SecurityTrainingAreaResultInputDto": {
        "type": "object",
        "properties": {
          "areaId": { "type": "string" },
          "result": { "type": "string", "enum": ["PASS", "FAIL"] },
          "imageFileIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["areaId", "result"]
      },
      "CreateCabinSecuritySearchTrainingDto": {
        "type": "object",
        "properties": {
          "shipNumber": { "type": "string" },
          "gateId": { "type": "string" },
          "shiftOccurrenceId": { "type": "string" },
          "areaResults": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SecurityTrainingAreaResultInputDto"
            }
          },
          "otherFindings": { "type": "string" },
          "additionalNotes": { "type": "string" },
          "generalPictureFileIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["shipNumber", "gateId", "areaResults"]
      },
      "EndOfShiftDelayInputDto": {
        "type": "object",
        "properties": {
          "sequenceNo": { "type": "number" },
          "delayCodeAlpha": { "type": "string" },
          "delayCodeNumber": { "type": "number" },
          "delayType": { "type": "string", "enum": ["PRIMARY", "SECONDARY"] },
          "reason": { "type": "string" }
        },
        "required": [
          "sequenceNo",
          "delayCodeAlpha",
          "delayCodeNumber",
          "delayType",
          "reason"
        ]
      },
      "CreateEndOfShiftReportDto": {
        "type": "object",
        "properties": {
          "shiftOccurrenceId": { "type": "string" },
          "lavObservationCompleted": { "type": "boolean" },
          "lavObservationReason": { "type": "string" },
          "cabinQualityCompleted": { "type": "boolean" },
          "cabinQualityReason": { "type": "string" },
          "callOffs": { "type": "number" },
          "tardyEarlyOut": { "type": "number" },
          "overtimeHours": { "type": "number" },
          "overtimeMinutes": { "type": "number" },
          "overtimeReason": { "type": "string" },
          "delaysTaken": { "type": "boolean" },
          "delayCount": { "type": "number" },
          "delays": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EndOfShiftDelayInputDto" }
          },
          "additionalNotes": { "type": "string" },
          "additionalPictureFileIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": [
          "lavObservationCompleted",
          "cabinQualityCompleted",
          "callOffs",
          "tardyEarlyOut",
          "overtimeHours",
          "overtimeMinutes",
          "delaysTaken"
        ]
      },
      "CreateEmployeeOneOnOneDto": {
        "type": "object",
        "properties": {
          "employeeUserId": { "type": "string" },
          "discussionText": { "type": "string" },
          "discussionAudioFileId": { "type": "string" },
          "additionalNote": { "type": "string" },
          "employeeRefusedToSign": { "type": "boolean" },
          "employeeSignatureFileId": { "type": "string" },
          "leaderSignatureFileId": { "type": "string" }
        },
        "required": [
          "employeeUserId",
          "employeeRefusedToSign",
          "leaderSignatureFileId"
        ]
      },
      "CreateFeedbackDto": {
        "type": "object",
        "properties": {
          "overallSatisfaction": {
            "type": "string",
            "enum": ["VERY_POOR", "POOR", "FAIR", "GOOD", "VERY_GOOD"]
          },
          "easeOfUse": {
            "type": "string",
            "enum": ["VERY_POOR", "POOR", "FAIR", "GOOD", "VERY_GOOD"]
          },
          "appPerformance": {
            "type": "string",
            "enum": ["VERY_POOR", "POOR", "FAIR", "GOOD", "VERY_GOOD"]
          },
          "usabilityIssues": { "type": "string" },
          "missingFeatures": { "type": "string" },
          "performanceIssues": { "type": "string" }
        },
        "required": ["overallSatisfaction", "easeOfUse", "appPerformance"]
      },
      "CreateDirectConversationDto": {
        "type": "object",
        "properties": { "userId": { "type": "string" } },
        "required": ["userId"]
      },
      "CreateGroupConversationDto": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "participantUserIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "avatarFileId": { "type": "string" }
        },
        "required": ["title", "participantUserIds"]
      },
      "SetFavoriteDto": {
        "type": "object",
        "properties": { "isFavorite": { "type": "boolean" } },
        "required": ["isFavorite"]
      },
      "SetMuteDto": {
        "type": "object",
        "properties": { "isMuted": { "type": "boolean" } },
        "required": ["isMuted"]
      },
      "MessageAttachmentDto": {
        "type": "object",
        "properties": {
          "fileId": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["IMAGE", "AUDIO", "DOCUMENT", "VIDEO"]
          }
        },
        "required": ["fileId", "kind"]
      },
      "PollOptionInputDto": {
        "type": "object",
        "properties": { "text": { "type": "string" } },
        "required": ["text"]
      },
      "PollInputDto": {
        "type": "object",
        "properties": {
          "question": { "type": "string" },
          "allowMultipleAnswers": { "type": "boolean" },
          "options": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PollOptionInputDto" }
          }
        },
        "required": ["question", "allowMultipleAnswers", "options"]
      },
      "EventInputDto": {
        "type": "object",
        "properties": {
          "eventName": { "type": "string" },
          "description": { "type": "string" },
          "startAt": { "type": "string" },
          "endAt": { "type": "string" },
          "locationText": { "type": "string" },
          "callType": { "type": "string", "enum": ["VIDEO", "VOICE"] },
          "callLinkUrl": { "type": "string" },
          "reminderOffsetMinutes": { "type": "number" },
          "allowGuests": { "type": "boolean", "default": false }
        },
        "required": ["eventName", "startAt"]
      },
      "LocationInputDto": {
        "type": "object",
        "properties": {
          "locationType": {
            "type": "string",
            "enum": ["CURRENT", "LIVE", "SEARCHED"]
          },
          "latitude": { "type": "number" },
          "longitude": { "type": "number" },
          "addressText": { "type": "string" },
          "liveExpiresAt": { "type": "string" }
        },
        "required": ["locationType", "latitude", "longitude"]
      },
      "ContactInputDto": {
        "type": "object",
        "properties": {
          "contactName": { "type": "string" },
          "contactPhone": { "type": "string" },
          "contactEmail": { "type": "string" }
        },
        "required": ["contactName", "contactPhone"]
      },
      "SendMessageDto": {
        "type": "object",
        "properties": {
          "messageType": {
            "type": "string",
            "enum": [
              "TEXT",
              "IMAGE",
              "AUDIO",
              "DOCUMENT",
              "VIDEO",
              "LOCATION",
              "CONTACT",
              "POLL",
              "EVENT",
              "SYSTEM"
            ]
          },
          "encryptedPayload": { "type": "string" },
          "previewText": { "type": "string" },
          "attachments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MessageAttachmentDto" }
          },
          "poll": { "$ref": "#/components/schemas/PollInputDto" },
          "event": { "$ref": "#/components/schemas/EventInputDto" },
          "location": { "$ref": "#/components/schemas/LocationInputDto" },
          "contact": { "$ref": "#/components/schemas/ContactInputDto" }
        },
        "required": ["messageType"]
      },
      "MessageReceiptDto": {
        "type": "object",
        "properties": { "conversationId": { "type": "string" } }
      },
      "PollVoteDto": {
        "type": "object",
        "properties": {
          "optionIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["optionIds"]
      }
    }
  }
}
