AVIATIONSTACK_ACTIVE_STATUS=active

MAIL_FROM=noreply@station-audit.local
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=

STORAGE_DRIVER=cloudinary
STORAGE_LOCAL_ROOT=storage
