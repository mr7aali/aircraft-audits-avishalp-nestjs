NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_BASE_URL=http://localhost:3000

DATABASE_URL=postgresql://postgres:1234@localhost:5432/station_audit?schema=public

JWT_ACCESS_SECRET=replace_with_very_long_access_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_very_long_refresh_secret_min_32_chars
JWT_ACCESS_TTL=30m
JWT_REFRESH_TTL=14d
JWT_REMEMBER_ME_TTL=60d
AUTH_THROTTLE_TTL_SECONDS=60
AUTH_THROTTLE_LIMIT=10

REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

FLIGHTS_CACHE_TTL_SECONDS=300
FLIGHTS_PROVIDER_TIMEOUT_MS=15000
FLIGHTS_PROVIDER_LIMIT=100
AVIATIONSTACK_API_KEY=c7f22b8c1826df77f67651e97a300b17
